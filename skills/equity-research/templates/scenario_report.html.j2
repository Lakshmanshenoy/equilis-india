<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>{{ company.ticker }} Scenario Analysis — equilis</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=IBM+Plex+Sans:wght@400;600;700&family=IBM+Plex+Mono:wght@400;700&display=swap');
</style>
{% include "partials/_styles.html.j2" %}
</head>
<body>

{# ===================================================================
   PAGE 1 — COVER (scenario)
   =================================================================== #}
<div class="page cover-page">
  <div class="cover-accent-bar"></div>
  <div class="cover-header">
    <div class="cover-brand">equilis — india</div>
    <div class="cover-tagline">Scenario Analysis Report</div>
  </div>
  <hr class="cover-divider">
  <div class="cover-company-block">
    <div class="cover-company-name">{{ company.name | na("—") }}</div>
    <div class="cover-ticker-row">
      <span class="cover-ticker">{{ company.ticker }}</span>
      <span class="cover-sector">{{ company.sector | na("") }}</span>
    </div>
  </div>
  <div class="cover-footer">
    <div class="cover-footer-left">
      <div class="cover-footer-text">Report Date: {{ report_date | date_fmt }}</div>
    </div>
    <div class="cover-footer-right">
      <div class="cover-footer-text">Analytical projections only. Not a price target.</div>
    </div>
  </div>
</div>

{# ===================================================================
   PAGE 2 — SCENARIO ANALYSIS
   =================================================================== #}
<div class="page">
  {% include "partials/_page_header.html.j2" %}
  <div class="section-body">
    <div class="section-title">Earnings Scenario Analysis</div>

    <div class="alert alert-warn" style="margin-bottom:4mm;">
      <strong>Disclaimer:</strong> The scenarios below are analytical projections only.
      They do not constitute a price target or any form of investment recommendation.
    </div>

    {% include "partials/_scenario_band.html.j2" %}

    {% if sensitivity_table %}
    <div class="subsection-title" style="margin-top:6mm;">Sensitivity Table</div>
    <table class="data-table">
      <thead>
        <tr>
          {% for col in sensitivity_table.keys() %}
          <th>{{ col }}</th>
          {% endfor %}
        </tr>
      </thead>
      <tbody>
        <tr>
          {% for val in sensitivity_table.values() %}
          <td>{{ val | na("—") }}</td>
          {% endfor %}
        </tr>
      </tbody>
    </table>
    {% endif %}

    {% if macro_context %}
    <div class="subsection-title" style="margin-top:5mm;">Macro Context</div>
    <div class="muted small">{{ macro_context }}</div>
    {% endif %}

    <div class="subsection-title" style="margin-top:5mm;">Current Snapshot</div>
    <table class="data-table">
      <tr><td>CMP</td><td>{% if price %}₹{{ "%.2f"|format(price.cmp) }}{% else %}N/A{% endif %}</td></tr>
      <tr><td>P/E (TTM)</td><td>{{ ratios.pe_ttm | ratio if ratios.pe_ttm is not none else "—" }}</td></tr>
      <tr><td>EPS (TTM)</td><td>{% if ratios.eps_ttm is not none %}₹{{ "%.2f"|format(ratios.eps_ttm) }}{% else %}—{% endif %}</td></tr>
      <tr><td>PAT (TTM)</td><td>{{ ratios.pat_ttm | inr if ratios.pat_ttm is not none else "—" }}</td></tr>
    </table>

    <div class="subsection-title" style="margin-top:5mm;">Disclaimer</div>
    <div class="compliance-box">
      <div class="compliance-box-title">Important Notice — Not Investment Advice</div>
      <div class="full-disclaimer">{{ disclaimer }}</div>
    </div>
  </div>
  {% include "partials/_page_footer.html.j2" %}
</div>

</body>
</html>
