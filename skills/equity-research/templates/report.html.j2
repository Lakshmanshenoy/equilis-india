<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ company.ticker }} — equilis Equity Research Report</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=IBM+Plex+Sans:wght@400;600;700&family=IBM+Plex+Mono:wght@400;700&display=swap');
</style>
{% include "partials/_styles.html.j2" %}
</head>
<body>

{# ===================================================================
   PAGE 1 — COVER
   =================================================================== #}
{% include "partials/_cover.html.j2" %}

{# ===================================================================
   PAGE 2 — EXECUTIVE SUMMARY + RATIO SNAPSHOT
   =================================================================== #}
<div class="page">
  {% include "partials/_page_header.html.j2" %}
  <div class="section-body">
    <div class="section-title">Executive Summary</div>

    <!-- Company overview row -->
    <div class="two-col" style="margin-bottom:5mm;">
      <div class="col-left">
        <div class="subsection-title">Company</div>
        <table class="data-table">
          <tr><td>Name</td><td>{{ company.name | na("—") }}</td></tr>
          <tr><td>Ticker</td><td class="mono gold">{{ company.ticker }}</td></tr>
          <tr><td>Exchange</td><td>{{ company.exchange | na("—") }}</td></tr>
          <tr><td>Sector</td><td>{{ company.sector | na("—") }}</td></tr>
          <tr><td>Industry</td><td>{{ company.industry | na("—") }}</td></tr>
        </table>
      </div>
      <div class="col-right">
        <div class="subsection-title">Market Data</div>
        <table class="data-table">
          <tr><td>CMP</td><td>{% if price %}₹{{ "%.2f"|format(price.cmp) }}{% else %}N/A{% endif %}</td></tr>
          <tr><td>52-Week High</td><td>{% if price and price.week52_high %}₹{{ "%.2f"|format(price.week52_high) }}{% else %}—{% endif %}</td></tr>
          <tr><td>52-Week Low</td><td>{% if price and price.week52_low %}₹{{ "%.2f"|format(price.week52_low) }}{% else %}—{% endif %}</td></tr>
          <tr><td>Market Cap</td><td>{{ market.market_cap | inr if market and market.market_cap else "—" }}</td></tr>
          <tr><td>Enterprise Value</td><td>{{ market.enterprise_value | inr if market and market.enterprise_value else "—" }}</td></tr>
        </table>
      </div>
    </div>

    {% if validation_issues %}
    <div class="subsection-title">Validation Notes</div>
    {% for issue in validation_issues %}
    <div class="alert alert-warn" style="margin-bottom:2mm;">{{ issue }}</div>
    {% endfor %}
    {% endif %}

    {% if macro_context %}
    <div class="subsection-title">Macro Context</div>
    <div class="muted small">{{ macro_context }}</div>
    {% endif %}
  </div>
  {% include "partials/_page_footer.html.j2" %}
</div>

{# ===================================================================
   PAGE 3 — FINANCIAL HISTORY + RATIOS
   =================================================================== #}
<div class="page">
  {% include "partials/_page_header.html.j2" %}
  <div class="section-body">
    <div class="section-title">Financial Performance</div>
    <div class="subsection-title">5-Year History</div>
    {% include "partials/_table.html.j2" %}
    <div class="subsection-title" style="margin-top:5mm;">Key Ratios</div>
    {% include "partials/_ratio_group.html.j2" %}
  </div>
  {% include "partials/_page_footer.html.j2" %}
</div>

{# ===================================================================
   PAGE 4 — DUPONT + CASH FLOW QUALITY
   =================================================================== #}
<div class="page">
  {% include "partials/_page_header.html.j2" %}
  <div class="section-body">
    <div class="section-title">Quality Analysis</div>

    <div class="subsection-title">DuPont ROE Decomposition</div>
    {% include "partials/_dupont.html.j2" %}

    <div class="subsection-title" style="margin-top:6mm;">Cash Flow Quality</div>
    {% include "partials/_cf_quality.html.j2" %}
  </div>
  {% include "partials/_page_footer.html.j2" %}
</div>

{# ===================================================================
   PAGE 5 — SCENARIO ANALYSIS
   =================================================================== #}
<div class="page">
  {% include "partials/_page_header.html.j2" %}
  <div class="section-body">
    <div class="section-title">Scenario Analysis</div>
    <div class="alert alert-warn" style="margin-bottom:4mm;">
      <strong>Disclaimer:</strong> The scenarios below are analytical projections only.
      They do not constitute a price target or any form of investment recommendation.
      All scenarios depend on assumptions that may not materialise.
    </div>
    {% include "partials/_scenario_band.html.j2" %}
  </div>
  {% include "partials/_page_footer.html.j2" %}
</div>

{# ===================================================================
   PAGE 6 — RED FLAGS + ALTMAN Z-SCORE
   =================================================================== #}
<div class="page">
  {% include "partials/_page_header.html.j2" %}
  <div class="section-body">
    <div class="section-title">Risk Assessment</div>

    <div class="two-col">
      <div class="col-left">
        <div class="subsection-title">Red Flag Scan</div>
        {% include "partials/_red_flags.html.j2" %}
      </div>
      <div class="col-right">
        <div class="subsection-title">Altman Z-Score</div>
        {% include "partials/_altman.html.j2" %}
      </div>
    </div>
  </div>
  {% include "partials/_page_footer.html.j2" %}
</div>

{# ===================================================================
   PAGE 7 — SOURCES + DISCLAIMER
   =================================================================== #}
<div class="page">
  {% include "partials/_page_header.html.j2" %}
  <div class="section-body">
    <div class="section-title">Data Sources &amp; Compliance</div>

    <div class="subsection-title">Data Sources</div>
    {% include "partials/_sources.html.j2" %}

    <div class="subsection-title" style="margin-top:6mm;">Full Disclaimer</div>
    <div class="compliance-box">
      <div class="compliance-box-title">Important Notice — Not Investment Advice</div>
      <div class="full-disclaimer">{{ disclaimer }}</div>
    </div>

    <div class="muted small" style="margin-top:4mm;">
      Report generated: {{ report_date | date_fmt }} · Version {{ report_version }} · equilis-india
    </div>
  </div>
  {% include "partials/_page_footer.html.j2" %}
</div>

</body>
</html>
